{
  "name": "durable-machines-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "typecheck": "pnpm -r typecheck",
    "lint:deps": "depcruise packages/*/src --config .dependency-cruiser.mjs",
    "lint:complexity": "fta packages/ --config-path fta.json",
    "lint:arch": "pnpm lint:deps && pnpm lint:complexity",
    "demo": "pnpm --filter @durable-machines/example-webhook-approval pg:demo",
    "demo:up": "docker compose -f docker-compose.demo.yml up -d --build --wait",
    "demo:down": "docker compose -f docker-compose.demo.yml down",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "dependency-cruiser": "^17.3.8",
    "fta-cli": "^3.0.0"
  }
}
