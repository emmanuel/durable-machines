{
  "name": "@durable-xstate/durable-machine",
  "version": "0.2.0",
  "description": "Durable XState v5 state machines with pluggable backends",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dbos": {
      "types": "./dist/dbos/index.d.ts",
      "import": "./dist/dbos/index.js"
    },
    "./pg": {
      "types": "./dist/pg/index.d.ts",
      "import": "./dist/pg/index.js"
    },
    "./pg-native": {
      "types": "./dist/pg-native/index.d.ts",
      "import": "./dist/pg-native/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "keywords": [
    "xstate",
    "durable",
    "workflow",
    "state-machine",
    "statechart",
    "dbos",
    "postgres"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanuel/durable-xstate.git",
    "directory": "packages/durable-machine"
  },
  "homepage": "https://github.com/emmanuel/durable-xstate/tree/main/packages/durable-machine",
  "bugs": {
    "url": "https://github.com/emmanuel/durable-xstate/issues"
  },
  "author": "Emmanuel Gomez",
  "peerDependencies": {
    "xstate": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@dbos-inc/dbos-sdk": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "@dbos-inc/dbos-sdk": "^4.0.0"
  },
  "devDependencies": {
    "@dbos-inc/dbos-sdk": "^4.0.0",
    "@electric-sql/pglite": "^0.3.16",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@types/node": "^24",
    "@types/pg": "^8.18.0",
    "pg": "^8.11.3",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "xstate": "^5.19.0"
  },
  "dependencies": {
    "@durable-xstate/expr": "workspace:*",
    "@opentelemetry/api": "^1.9.0"
  }
}
