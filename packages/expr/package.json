    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanuel/durable-xstate.git",
    "directory": "packages/expr"
  },
  "author": "Emmanuel Gomez",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
