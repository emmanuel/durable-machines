{
  "name": "@durable-xstate/expr",
  "version": "0.1.0",
  "description": "JSON expression evaluator for serializable XState v5 machine logic",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
