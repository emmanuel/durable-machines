{
  "name": "xstate-dbos",
  "version": "0.1.0",
  "description": "Durable XState v5 state machines powered by DBOS Transact",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=24"
  },
  "license": "MIT",
  "keywords": [
    "xstate",
    "dbos",
    "durable",
    "workflow",
    "state-machine",
    "statechart"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emmanuel/xstate-dbos.git",
    "directory": "packages/xstate-dbos"
  },
  "homepage": "https://github.com/emmanuel/xstate-dbos/tree/main/packages/xstate-dbos",
  "bugs": {
    "url": "https://github.com/emmanuel/xstate-dbos/issues"
  },
  "author": "Emmanuel Gomez",
  "peerDependencies": {
    "@dbos-inc/dbos-sdk": "^4.0.0",
    "xstate": "^5.0.0"
  },
  "devDependencies": {
    "@dbos-inc/dbos-sdk": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "xstate": "^5.19.0"
  }
}
